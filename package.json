{
	"name": "agentverus-scanner",
	"version": "0.8.1",
	"description": "AgentVerus skill trust scanner — security and behavioral analysis for AI agent skills",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/agentverus/agentverus-scanner.git"
	},
	"engines": {
		"node": ">=22"
	},
	"exports": {
		".": "./dist/scanner/index.js",
		"./types": "./dist/scanner/types.js",
		"./parser": "./dist/scanner/parser.js",
		"./source": "./dist/scanner/source.js",
		"./sbom": "./dist/scanner/sbom.js",
		"./badges": "./dist/scanner/badges.js",
		"./registry": "./dist/registry/index.js"
	},
	"main": "./dist/scanner/index.js",
	"types": "./dist/scanner/index.d.ts",
	"bin": {
		"agentverus": "dist/scanner/cli.js",
		"agentverus-scanner": "dist/scanner/cli.js"
	},
	"files": [
		"dist",
		"LICENSE.md",
		"README.md"
	],
	"scripts": {
		"dev": "tsx watch src/scanner/cli.ts",
		"build": "node scripts/clean-dist.mjs && tsc",
		"build:actions": "pnpm build && node scripts/build-actions.mjs",
		"test": "vitest run",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"scan": "tsx src/scanner/cli.ts",
		"prepublishOnly": "pnpm build"
	},
	"packageManager": "pnpm@10.28.0",
	"pnpm": {
		"overrides": {
			"@hono/node-server@<1.19.13": "^1.19.13",
			"hono@<4.12.25": "^4.12.25",
			"fast-uri@<3.1.2": "^3.1.2",
			"ajv@<8.20.0": "^8.20.0",
			"path-to-regexp@<8.4.2": "^8.4.2",
			"express-rate-limit@<8.5.2": "^8.5.2",
			"qs@<6.15.2": "^6.15.2",
			"ip-address@<10.2.0": "^10.2.0"
		}
	},
	"dependencies": {
		"fflate": "^0.8.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@types/node": "^25.2.1",
		"@vitest/coverage-v8": "^4.0.18",
		"esbuild": "^0.27.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
